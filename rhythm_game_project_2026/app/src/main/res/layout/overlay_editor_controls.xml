<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_gravity="bottom"
    android:background="@color/ui_panel"
    android:orientation="vertical"
    android:padding="8dp">

    <SeekBar
        android:id="@+id/playbackSeekBar"
        android:layout_width="match_parent"
        android:layout_height="36dp"
        android:max="1000" />

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
        <Button android:id="@+id/playPauseButton" style="@style/GameButton" android:layout_width="0dp" android:layout_height="48dp" android:layout_weight="1" />
        <Button android:id="@+id/testButton" style="@style/GameButton" android:layout_width="0dp" android:layout_height="48dp" android:layout_weight="1" android:text="@string/action_test" />
    </LinearLayout>

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
        <Button android:id="@+id/bpmButton" style="@style/GameButton" android:layout_width="0dp" android:layout_height="48dp" android:layout_weight="1" android:text="@string/action_bpm" />
        <Button android:id="@+id/snapButton" style="@style/GameButton" android:layout_width="0dp" android:layout_height="48dp" android:layout_weight="1" android:text="@string/action_snap" />
        <Button android:id="@+id/upButton" style="@style/GameButton" android:layout_width="0dp" android:layout_height="48dp" android:layout_weight="1" android:text="@string/action_up" />
        <Button android:id="@+id/downButton" style="@style/GameButton" android:layout_width="0dp" android:layout_height="48dp" android:layout_weight="1" android:text="@string/action_down" />
    </LinearLayout>
</LinearLayout>
